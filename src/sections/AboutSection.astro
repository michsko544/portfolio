---
import PageHeader from "src/components/PageHeader.astro"
import Table from "src/components/Table.astro"

const chipText = "MORE ABOUT ME";
const pageTitle = "How do I work as an AI-first Developer?";
const tableTitle = "FAVOURITE STACK & TOOLS";
const tableItems = [{
  label: "AI Agent",
  value: "Claude Code"
},{
  label: "Language",
  value: "TypeScript"
},{
  label: "Framework",
  value: "React",
},{
  label: "Styling",
  value: "TailwindCSS",
},{
  label: "Runtime Environment",
  value: "Node.js",
},{
  label: "Building Tool",
  value: "Vite.js",
},{
  label: "Package Manager",
  value: "PNPM",
}, {
  label: "Git Repository",
  value: "GitHub"
}]
---

<section id="about" class="contentSection">
  <div class="flex flex-col gap-12">
    <PageHeader title={pageTitle} chipText={chipText}>
      <p slot="description">As an AI web developer, my favorite technology is React supported by TypeScript, but I’m comfortable working with a wide range of technologies to deliver the best solutions tailored to each project.</p>
    </PageHeader>
    <Table title={tableTitle} items={tableItems} />
  </div>
</section>
