---
import PageHeader from "src/components/PageHeader.astro";
import ShiningStar from "src/components/ShiningStar.astro";
import TechnologyLists from "src/components/TechnologyLists.astro";

const chipText = "SKILLS & KNOWLEDGE"
const pageTitle = "Known technologies"
const technologies = [
  {
    title: "LANGUAGES",
    items: ["JAVASCRIPT", "TYPESCRIPT", "PYTHON", "C++", "BASH"]
  },
  {
    title: "FRAMEWORKS",
    items: ["REACT", "SVELTE", "NEXT.JS", "ASTRO", "REMIX", "VUE", "PREACT", "SOLID", "NUXT.JS"]
  },
  {
    title: "STYLING",
    items: ["SASS/SCSS", "TAILWINDCSS", "SHADCN/UI", "BASE UI", "SHOPIFY POLARIS", "STYLED-COMPONENTS", "EMOTION", "MUI", "ANTDESIGN", "SEMANTIC UI"]
  },
  {
    title: "FRONTEND TOOLS",
    items: ["VITE.JS", "WEBPACK", "ESLINT", "PRETTIER", "BIOME", "OXLINT", "TURBOPACK", "ROLLUP.JS", "GULP.JS", "ESBUILD", "BABEL", "SWC", "POSTCSS", "GRAPHQL-CODEGEN", "PNPM", "NPM", "NGROK"]
  },
  {
    title: "AI AGENTS",
    items: ["CLAUDE CODE", "GEMINI", "CODEX", "OPENCODE", "CURSOR", "GITHUB COPILOT", "OPENCLAW"]
  },
  {
    title: "DEVOPS",
    items: ["DOCKER", "GITHUB ACTIONS", "GITLAB CI", "NGINX", "KUBERNETES", "CADDY", "LET’S ENCRYPT", "GITHUB PAGES", "DIGITALOCEAN", "OVH", "VERCEL", "NETLIFY"]
  },
  {
    title: "TESTING",
    items: ["VITEST", "PLAYWRIGHT", "JEST", "CHAI"]
  },
  {
    title: "BACKEND",
    items: ["NODE.JS", "POSTGRESQL", "SQLITE", "PRISMA"]
  },
  {
    title: "OTHER",
    items: ["GIT", "GITLAB", "GITHUB", "REST API", "GRAPHQL", "MISE"]
  },
]
---

<section id="technologies" class="relative overflow-hidden">
  <div class="contentSection">
    <div class="flex flex-col gap-12">
      <PageHeader title={pageTitle} chipText={chipText}>
        <p slot="description">In the <strong>era of AI</strong>, no technology is a challenge for me. Backed by solid <strong>engineering fundamentals</strong>, I pick the best tools for the job to build <strong>high-quality, scalable web apps</strong>. Here's a&nbsp;quick overview of the selected technologies I am proficient&nbsp;in.</p>
      </PageHeader>
      <TechnologyLists technologies={technologies}/>
    </div>
  </div>
    <div class="absolute right-[-70px] bottom-0 lg:right-[3%] xl:right-[18%]">
      <div class="w-[140px] h-[140px] lg:w-[308px] lg:h-[308px]">
      <ShiningStar />
    </div>
  </div>
</section>
